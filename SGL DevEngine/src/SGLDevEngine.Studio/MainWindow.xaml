<Window x:Class="SGLDevEngine.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SGL DevEngine v1.1.1 Beta"
        Height="800" Width="1400"
        Background="#1E1E1E"
        Foreground="#FFFFFF">
    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="50" Background="#252526" Margin="0">
            <Button Content="New" Width="70" Margin="5" Click="NewProject_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="Open" Width="70" Margin="5" Click="OpenProject_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="Save" Width="70" Margin="5" Click="SaveProject_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Separator Background="#3E3E42" Width="2" Height="30" VerticalAlignment="Center"/>
            <Button Content="Compile" Width="80" Margin="5" Click="CompileGraph_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="Generate" Width="80" Margin="5" Click="GenerateCode_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="Run" Width="70" Margin="5" Click="RunGraph_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Separator Background="#3E3E42" Width="2" Height="30" VerticalAlignment="Center"/>
            <Button Content="AI Prompt" Width="90" Margin="5" Click="AIPrompt_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="SOC Agent" Width="90" Margin="5" Click="SOCAgent_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <Button Content="Settings" Width="90" Margin="5" Click="Settings_Click" Background="#007ACC" Foreground="White" Padding="5"/>
            <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" Foreground="#999999" FontSize="11" Text="SGL DevEngine - Visual Software Architecture Builder"/>
        </StackPanel>

        <!-- Main Grid -->
        <Grid Background="#1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Node Library -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Node Library" Background="#007ACC" Foreground="White" Padding="8" FontWeight="Bold"/>
                    <TreeView Background="Transparent" Foreground="White" x:Name="NodeLibraryTree" Margin="5">
                        <TreeViewItem Header="Execution Nodes" IsExpanded="True">
                            <TreeViewItem Header="HTTP Request" Tag="HttpRequest"/>
                            <TreeViewItem Header="Database Query" Tag="DatabaseQuery"/>
                            <TreeViewItem Header="File Operations" Tag="FileOp"/>
                        </TreeViewItem>
                        <TreeViewItem Header="Data Transform">
                            <TreeViewItem Header="String Operation" Tag="StringOp"/>
                            <TreeViewItem Header="JSON Parse" Tag="JSONParse"/>
                        </TreeViewItem>
                        <TreeViewItem Header="Control Flow">
                            <TreeViewItem Header="If Statement" Tag="If"/>
                            <TreeViewItem Header="Loop" Tag="Loop"/>
                        </TreeViewItem>
                        <TreeViewItem Header="Services">
                            <TreeViewItem Header="API Gateway" Tag="APIGateway"/>
                            <TreeViewItem Header="Auth Service" Tag="AuthService"/>
                            <TreeViewItem Header="Event Publisher" Tag="EventPub"/>
                        </TreeViewItem>
                        <TreeViewItem Header="AI &amp; ML">
                            <TreeViewItem Header="LLM Prompt" Tag="LLMPrompt"/>
                            <TreeViewItem Header="Embedding" Tag="Embedding"/>
                        </TreeViewItem>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Center Panel - Main Tabs -->
            <TabControl Grid.Column="1" Background="#1E1E1E" Foreground="White" x:Name="MainTabControl">
                <!-- Blueprint Editor -->
                <TabItem Header="Blueprint Editor" Background="#252526" Foreground="White">
                    <Grid Background="#2D2D30">
                        <Canvas x:Name="GraphCanvas" Background="#2D2D30" MouseDown="Canvas_MouseDown"/>
                        <TextBlock Foreground="#666666" VerticalAlignment="Center" HorizontalAlignment="Center" Text="Blueprint Graph Editor - Drag nodes from library" FontSize="14" IsHitTestVisible="False"/>
                    </Grid>
                </TabItem>

                <!-- Architecture Designer -->
                <TabItem Header="Architecture Designer" Background="#252526" Foreground="White">
                    <DockPanel Background="#1E1E1E">
                        <StackPanel DockPanel.Dock="Top" Margin="15,10,15,5" Orientation="Vertical">
                            <TextBlock Text="System Architecture &amp; Project Structure" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>
                            <Button Content="Generate Architecture" Click="GenerateArchitecture_Click" Width="160" Height="35" Background="#007ACC" Foreground="White"/>
                        </StackPanel>
                        <TreeView x:Name="ArchitectureTree" Background="#2D2D30" Foreground="White" Margin="15" Padding="5"/>
                    </DockPanel>
                </TabItem>

                <!-- Generated Code -->
                <TabItem Header="Generated Code" Background="#252526" Foreground="White">
                    <DockPanel Background="#1E1E1E">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="45" Margin="10,10,10,5">
                            <TextBlock Text="Language:" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                            <ComboBox x:Name="LanguageSelect" Width="100" Background="#3C3C3C" Foreground="White">
                                <ComboBoxItem>C#</ComboBoxItem>
                                <ComboBoxItem>Python</ComboBoxItem>
                                <ComboBoxItem>C++</ComboBoxItem>
                            </ComboBox>
                            <Button Content="Copy Code" Click="CopyCode_Click" Width="100" Background="#007ACC" Foreground="White" Margin="10,0,0,0"/>
                            <Button Content="Export" Click="ExportCode_Click" Width="80" Background="#007ACC" Foreground="White" Margin="5,0,0,0"/>
                        </StackPanel>
                        <TextBox x:Name="CodeViewer" Background="#1E1E1E" Foreground="#D4D4D4" TextWrapping="Wrap" FontFamily="Courier New" FontSize="11" IsReadOnly="True" Text="// Generated code will appear here" Margin="10"/>
                    </DockPanel>
                </TabItem>

                <!-- AI Builder -->
                <TabItem Header="AI Builder" Background="#252526" Foreground="White">
                    <ScrollViewer Background="#1E1E1E" Margin="15">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="AI Architecture Builder" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="Describe your application:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <TextBox x:Name="AIPromptBox" Height="100" Background="#3C3C3C" Foreground="White" TextWrapping="Wrap" Text="Create a secure login system with JWT authentication and database..." Margin="0,0,0,10"/>
                            <Button Content="Generate Architecture" Click="GenerateFromAI_Click" Height="40" Background="#007ACC" Foreground="White" Width="160"/>
                            <TextBlock Text="Generated Blueprint:" Foreground="#CCCCCC" Margin="0,20,0,5" FontWeight="Bold"/>
                            <TextBox x:Name="AIResultBox" Height="250" Background="#2D2D30" Foreground="#CCCCCC" TextWrapping="Wrap" IsReadOnly="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Execution -->
                <TabItem Header="Execution" Background="#252526" Foreground="White">
                    <DockPanel Background="#1E1E1E">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="50" Margin="10">
                            <Button Content="Execute Graph" Click="ExecuteGraph_Click" Width="120" Height="40" Background="#00AA00" Foreground="White" FontWeight="Bold"/>
                            <Button Content="Stop" Click="StopExecution_Click" Width="100" Height="40" Background="#AA0000" Foreground="White" Margin="10,0,0,0" FontWeight="Bold"/>
                            <TextBlock VerticalAlignment="Center" Margin="20,0" Foreground="#AAAAAA" x:Name="ExecutionStatus" Text="Ready"/>
                        </StackPanel>
                        <TextBox x:Name="ExecutionLog" Background="#1E1E1E" Foreground="#00FF00" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Courier New" FontSize="10" Margin="10"/>
                    </DockPanel>
                </TabItem>

                <!-- Deployment -->
                <TabItem Header="Deployment" Background="#252526" Foreground="White">
                    <ScrollViewer Background="#1E1E1E" Margin="15">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Deployment Manager" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="Build Options:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                            <CheckBox Content="Generate Dockerfile" Foreground="White" Margin="0,0,0,3"/>
                            <CheckBox Content="Generate Docker Compose" Foreground="White" Margin="0,0,0,3"/>
                            <CheckBox Content="Generate Kubernetes YAML" Foreground="White" Margin="0,0,0,3"/>
                            <CheckBox Content="Generate CI/CD Pipeline" Foreground="White" Margin="0,0,0,10"/>
                            <Button Content="Build Project" Click="BuildProject_Click" Height="40" Width="140" Background="#007ACC" Foreground="White" Margin="0,0,0,10"/>
                            <Button Content="Generate Deployment Files" Click="GenerateDeployment_Click" Height="40" Width="180" Background="#007ACC" Foreground="White"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Right Panel - Properties -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Properties" Background="#007ACC" Foreground="White" Padding="8" FontWeight="Bold"/>
                    <ScrollViewer>
                        <StackPanel x:Name="PropertiesPanel" Margin="10" Orientation="Vertical">
                            <TextBlock Text="Node Properties" Foreground="#CCCCCC" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Select a node to edit properties" Foreground="#888888" Margin="0,20,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
